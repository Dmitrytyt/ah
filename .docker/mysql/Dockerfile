FROM mariadb:10.11

# Копируем локальный my.cnf с новым именем, чтобы загружался последним и не переопределялось другими конфигами
COPY my.cnf /etc/mysql/conf.d/99-my.cnf

# Устанавливаем права на 99-my.cnf
# (MySQL игнорирует файлы конфигурации, у которых слишком "широкие" права)
RUN chmod 644 /etc/mysql/conf.d/99-my.cnf