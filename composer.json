{
  "name": "candidate/php-smart-blog",
  "description": "Simple MVC blog on pure PHP, MySQL and Smarty",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "smarty/smarty": "^5.4",
    "vlucas/phpdotenv": "^5.6",
    "fakerphp/faker": "^1.24",
    "ext-pdo": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "serve": "php -S 0.0.0.0:8000 -t public",
    "migrate": "php database/migrate.php",
    "seed": "php database/seed.php"
  }
}
